{
  "rewrites": [
    {
      "source": "/api/admin-summary",
      "destination": "/api/cron-reminders?adminResource=summary"
    },
    {
      "source": "/api/admin-users",
      "destination": "/api/cron-reminders?adminResource=users"
    },
    {
      "source": "/api/admin-events",
      "destination": "/api/cron-reminders?adminResource=events"
    },
    {
      "source": "/api/admin-errors",
      "destination": "/api/cron-reminders?adminResource=errors"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
